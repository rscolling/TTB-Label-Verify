# Copy to .env and fill in. The key stays server-side only (R8) — never in client code.
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional demo protection (QA P0-2). When set, /api/verify* and /api/ingest-form
# require matching X-API-Key (or Authorization: Bearer). Health + UI stay open.
# VERIFY_API_KEY=

# Optional per-IP request cap per minute for protected API routes (0 = off).
# RATE_LIMIT_PER_MINUTE=60

# Upload size caps (bytes). Defaults: 15MB image, 20MB form, 100MB batch total.
# MAX_IMAGE_BYTES=15728640
# MAX_FORM_BYTES=20971520
# MAX_BATCH_TOTAL_BYTES=104857600

# EXTRACTION_MODEL=claude-sonnet-5
# BATCH_CONCURRENCY=4
